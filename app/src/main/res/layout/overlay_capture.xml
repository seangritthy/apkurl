<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_bg_gradient"
    android:padding="0dp"
    android:elevation="8dp">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/overlayHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1AFFFFFF"
        android:clickable="true"
        android:focusable="true">

        <!-- Drag Handle Indicator -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="#33FFFFFF"
            android:backgroundTint="#33FFFFFF"
            android:backgroundTintMode="src_over"
            android:alpha="0.5" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/overlayAppIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitCenter"
                android:background="@drawable/badge_background"
                android:padding="2dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/overlayAppNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/overlay_title"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">
                    <View
                        android:id="@+id/overlayStatusDot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/dot_idle" />
                    <TextView
                        android:id="@+id/overlayStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/overlay_status_idle"
                        android:textColor="#99ADC8FF"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/overlayLangBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/overlay_lang_en"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/btn_outline_premium" />

            <TextView
                android:id="@+id/overlayCloseBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="✕"
                android:textColor="#66FFFFFF"
                android:textSize="18sp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF" />

    <!-- Info Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/overlayDeviceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_device_label"
                android:textColor="#99BBC7DB"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/overlayDeviceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_device_placeholder"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/overlayAndroidLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_android_label"
                android:textColor="#99BBC7DB"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/overlayAndroidText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_android_placeholder"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/overlayVersionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:text="@string/overlay_version_placeholder"
            android:textColor="#4DFFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Logs Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#26000000"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:id="@+id/overlayLogLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/overlay_log_label"
                android:textColor="#99BBC7DB"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/overlayClearBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear_logs"
                android:textColor="#2196F3"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/overlayLogsText"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/overlay_log_bg"
            android:padding="8dp"
            android:textColor="#00E676"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:scrollbars="vertical"
            android:text="@string/no_logs" />
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#1AFFFFFF">

        <LinearLayout
            android:id="@+id/overlayStartBtn"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/btn_start_premium"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_play"
                app:tint="#FFFFFF" />
            <TextView
                android:id="@+id/overlayStartLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/overlay_start"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/overlayStopBtn"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/btn_stop_premium"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_media_pause"
                app:tint="#FFFFFF" />
            <TextView
                android:id="@+id/overlayStopLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/overlay_stop"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dp"
        android:text="@string/overlay_footer"
        android:textColor="#4DFFFFFF"
        android:textSize="11sp"
        android:letterSpacing="0.2" />

</LinearLayout>
