<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginTop="4dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#00000000"
        app:strokeWidth="1dp"
        app:strokeColor="#221B6EF3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/overlay_bg_gradient">

            <!-- ═══ Premium Header ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/overlay_header_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp">

                <!-- App icon / branding -->
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="fitCenter" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overlay_title"
                        android:textColor="#ADC8FF"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:letterSpacing="0.03" />

                    <TextView
                        android:id="@+id/overlayVersionText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overlay_version_placeholder"
                        android:textColor="#66ADC8FF"
                        android:textSize="9sp"
                        android:layout_marginTop="1dp" />

                </LinearLayout>

                <!-- Language toggle -->
                <TextView
                    android:id="@+id/overlayLangBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:background="@drawable/btn_outline_premium"
                    android:text="🌐 EN"
                    android:textColor="#ADC8FF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <!-- Close button -->
                <TextView
                    android:id="@+id/overlayCloseBtn"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginStart="6dp"
                    android:gravity="center"
                    android:background="@drawable/btn_close_premium"
                    android:text="✕"
                    android:textColor="#FF6B6B"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ═══ Device Info Bar ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/overlay_info_bg"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/overlayDeviceLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overlay_device_label"
                        android:textColor="#55ADC8FF"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/overlayDeviceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overlay_device_placeholder"
                        android:textColor="#99ADC8FF"
                        android:textSize="9.5sp"
                        android:layout_marginTop="1dp"
                        android:singleLine="true"
                        android:ellipsize="end" />

                </LinearLayout>

                <View
                    android:layout_width="6dp"
                    android:layout_height="0dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/overlay_info_bg"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/overlayAndroidLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overlay_android_label"
                        android:textColor="#55ADC8FF"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/overlayAndroidText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overlay_android_placeholder"
                        android:textColor="#99ADC8FF"
                        android:textSize="9.5sp"
                        android:layout_marginTop="1dp"
                        android:singleLine="true"
                        android:ellipsize="end" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══ Divider ═══ -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/overlay_divider" />

            <!-- ═══ Control Buttons Row ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp">

                <!-- Start Button -->
                <LinearLayout
                    android:id="@+id/overlayStartBtn"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@drawable/btn_start_premium"
                    android:paddingHorizontal="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/overlayStartLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/overlay_start"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04" />

                </LinearLayout>

                <View
                    android:layout_width="8dp"
                    android:layout_height="0dp" />

                <!-- Stop Button -->
                <LinearLayout
                    android:id="@+id/overlayStopBtn"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@drawable/btn_stop_premium"
                    android:paddingHorizontal="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏹"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/overlayStopLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/overlay_stop"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══ Status indicator ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingBottom="4dp">

                <View
                    android:id="@+id/overlayStatusDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/btn_outline_premium" />

                <TextView
                    android:id="@+id/overlayStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/overlay_status_idle"
                    android:textColor="#66BBC7DB"
                    android:textSize="9sp" />

            </LinearLayout>

            <!-- ═══ Divider ═══ -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="14dp"
                android:background="@drawable/overlay_divider" />

            <!-- ═══ URL Log Area ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/overlayLogLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/overlay_log_label"
                        android:textColor="#55ADC8FF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/overlayClearBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:background="@drawable/btn_outline_premium"
                        android:text="@string/clear_logs"
                        android:textColor="#66ADC8FF"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:id="@+id/overlayLogsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="180dp"
                    android:scrollbars="vertical"
                    android:padding="10dp"
                    android:text="@string/no_logs"
                    android:textColor="#AABBC7DB"
                    android:textSize="9.5sp"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.4"
                    android:background="@drawable/overlay_log_bg" />

            </LinearLayout>

            <!-- ═══ Footer branding ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="8dp"
                android:text="@string/overlay_footer"
                android:textColor="#22ADC8FF"
                android:textSize="7sp"
                android:letterSpacing="0.15" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
