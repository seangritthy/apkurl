<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E17">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/playerToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0A0E17"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="#FFFFFF"
        app:title="@string/player_title"
        app:titleTextColor="#FFFFFF"
        app:titleTextAppearance="?attr/textAppearanceTitleMedium" />

    <TextView
        android:id="@+id/playerUrlText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:textColor="#99ADC8FF"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:maxLines="2"
        android:ellipsize="end"
        android:background="#1AFFFFFF" />

    <LinearLayout
        android:id="@+id/playerCaptureBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="12dp"
        android:background="#0A0E17">

        <TextView
            android:id="@+id/playerStartBtn"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/start_capture"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/btn_start_premium"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/playerStopBtn"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/stop_capture"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/btn_stop_premium"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/playerBackBtn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:text="Back"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/btn_outline_premium" />
    </LinearLayout>

    <TextView
        android:id="@+id/playerCapturedUrls"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#1AFFFFFF"
        android:textColor="#CCFFFFFF"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:overScrollMode="always"
        android:gravity="top|start"
        android:maxLines="5"
        android:ellipsize="end"
        android:text="" />

    <!-- ExoPlayer PlayerView for advanced playback -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerExoView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        android:visibility="gone"
        app:show_buffering="always"
        app:use_controller="true" />

    <WebView
        android:id="@+id/playerWebView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000" />

</LinearLayout>
